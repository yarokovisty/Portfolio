<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="style_current_img">
        <item name="android:layout_width">@dimen/width_current_icon</item>
        <item name="android:layout_height">@dimen/height_current_icon</item>
    </style>

    <style name="BaseText">
        <item name="android:textColor">@color/text</item>
    </style>

    <style name="style_description_icon">
        <item name="android:layout_width">@dimen/width_description_icon</item>
        <item name="android:layout_height">@dimen/height_description_icon</item>
        <item name="android:layout_marginTop">@dimen/marginTop_description_icon</item>
    </style>

    <style name="style_description_text" parent="BaseText">
        <item name="android:textSize">@dimen/size_description_text</item>
    </style>

    <style name="style_current_temp" parent="BaseText">
        <item name="android:textSize">@dimen/size_text_current_temp</item>
    </style>
    
    <style name="BaseCardView" parent="Widget.MaterialComponents.CardView">
        <item name="android:layout_margin">@dimen/margin_card_view</item>
        <item name="contentPadding">@dimen/padding_card_view</item>
        <item name="cardCornerRadius">@dimen/corner_radius_card_view</item>
    </style>

    <style name="style_title_card_view" parent="BaseText">
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/size_text_card_view</item>
        <item name="android:layout_marginBottom">@dimen/marginBottom_text_card_view</item>
    </style>

    <style name="style_param_text_card_view" parent="BaseText">
        <item name="android:textSize">@dimen/size_text_card_view</item>
    </style>

</resources>